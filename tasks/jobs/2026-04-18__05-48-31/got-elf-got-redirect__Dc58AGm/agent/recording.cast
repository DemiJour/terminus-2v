[103.570466, "i", "cat > /app/cmd/got-patch/main.go <<'EOF'\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/binary\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n)\n\n// Minimal ELF64 little-endian patcher for retargeting malloc relocations to a wrapper.\n// Hard rules: no debug/elf, no external deps.\n\nconst (\n\tEI_NIDENT = 16\n\n\t// e_ident offsets\n\tEI_CLASS = 4\n\tEI_DATA  = 5\n\n\tELFCLASS64 = 2\n\tELFDATA2LSB = 1\n\n\t// Section types\n\tSHT_NULL   = 0\n\tSHT_SYMTAB = 2\n\tSHT_STRTAB = 3\n\tSHT_RELA   = 4\n\tSHT_DYNSYM = 11\n)\n\ntype elf64Ehdr struct {\n\tIdent     [16]byte\n\tType      uint16\n\tMachine   uint16\n\tVersion   uint32\n\tEntry     uint64\n\tPhoff     uint64\n\tShoff     uint64\n\tFlags     uint32\n\tEhsize    uint16\n\tPhentsize uint16\n\tPhnum     uint16\n\tShentsize uint16\n\tShnum     uint16\n\tShstrndx  uint16\n}\n\ntype elf64Shdr struct {\n\tName      uint32\n\tType      uint32\n\tFlags     uint64\n\tAddr      uint64\n\tOff       uint64\n\tSize      uint64\n\tLink      uint32\n\tInfo      uint32\n\tAddralign uint64\n\tEntsize   uint64\n}\n\ntype elf64Sym struct {\n\tName  uint32\n\tInfo  byte\n"]
[103.570508, "i", "\tOther byte\n\tShndx uint16\n\tValue uint64\n\tSize  uint64\n}\n\ntype elf64Rela struct {\n\tOff    uint64\n\tInfo   uint64\n\tAddend int64\n}\n\nfunc elf64RelaSym(info uint64) uint32 { return uint32(info >> 32) }\nfunc elf64RelaType(info uint64) uint32 { return uint32(info & 0xffffffff) }\nfunc elf64RelaInfo(sym uint32, typ uint32) uint64 { return (uint64(sym) << 32) | uint64(typ) }\n\nfunc readAtFull(f *os.File, b []byte, off int64) error {\n\tn, err := f.ReadAt(b, off)\n\tif err != nil && err != io.EOF {\n\t\treturn err\n\t}\n\tif n != len(b) {\n\t\treturn io.ErrUnexpectedEOF\n\t}\n\treturn nil\n}\n\nfunc cstr(tab []byte, off uint32) (string, error) {\n\tif off >= uint32(len(tab)) {\n\t\treturn \"\", fmt.Errorf(\"string offset %d out of range (tab size %d)\", off, len(tab))\n\t}\n\ts := tab[off:]\n\ti := bytes.IndexByte(s, 0)\n\tif i < 0 {\n\t\treturn \"\", errors.New(\"unterminated string\")\n\t}\n\treturn string(s[:i]), nil\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, \"usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n\", filepath.Base(os.Args[0]))\n\tos.Exit(2)\n}\n\nfunc main()"]
[103.570527, "i", " {\n\tif len(os.Args) != 3 && len(os.Args) != 4 {\n\t\tusage()\n\t}\n\tinPath := os.Args[1]\n\toutPath := os.Args[2]\n\twrapper := \"logged_malloc\"\n\tif len(os.Args) == 4 {\n\t\twrapper = os.Args[3]\n\t}\n\n\tin, err := os.Open(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"open input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer in.Close()\n\n\tst, err := in.Stat()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"stat input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif st.Size() < 64 {\n\t\tfmt.Fprintf(os.Stderr, \"input too small to be ELF: %d bytes\\n\", st.Size())\n\t\tos.Exit(1)\n\t}\n\n\t// Read ELF header (64 bytes for ELF64)\n\tvar eh elf64Ehdr\n\thdrBuf := make([]byte, 64)\n\tif err := readAtFull(in, hdrBuf, 0); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read ELF header: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif err := binary.Read(bytes.NewReader(hdrBuf), binary.LittleEndian, &eh); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"parse ELF header: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif string(eh.Ident[0:4]) != \"\\x7fELF\" {\n\t\tfmt.Fprintf(os.Stderr, \"not an ELF file (bad magic)\\n\")\n\t\tos.Exit(1)\n\t}\n\tif e"]
[103.57054, "i", "h.Ident[EI_CLASS] != ELFCLASS64 {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF class %d (need 64-bit)\\n\", eh.Ident[EI_CLASS])\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF data encoding %d (need little-endian)\\n\", eh.Ident[EI_DATA])\n\t\tos.Exit(1)\n\t}\n\tif eh.Shoff == 0 || eh.Shentsize == 0 || eh.Shnum == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"ELF missing section headers (no Shoff/Shnum)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t// Read section headers\n\tshdrs := make([]elf64Shdr, eh.Shnum)\n\tshTableSize := int64(eh.Shentsize) * int64(eh.Shnum)\n\tshBuf := make([]byte, shTableSize)\n\tif err := readAtFull(in, shBuf, int64(eh.Shoff)); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read section headers: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfor i := 0; i < int(eh.Shnum); i++ {\n\t\tstart := i * int(eh.Shentsize)\n\t\tend := start + int(eh.Shentsize)\n\t\tif end > len(shBuf) {\n\t\t\tfmt.Fprintf(os.Stderr, \"section header buffer overrun\\n\")\n\t\t\tos.Exit(1)\n\t\t}\n\t\t// Only support standard 64-byte shdr size.\n\t\tif eh.Shentsize < 64 {\n\t\t\tf"]
[103.57086, "i", "mt.Fprintf(os.Stderr, \"unsupported Shentsize %d (need >= 64)\\n\", eh.Shentsize)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvar sh elf64Shdr\n\t\tif err := binary.Read(bytes.NewReader(shBuf[start:start+64]), binary.LittleEndian, &sh); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"parse shdr %d: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tshdrs[i] = sh\n\t}\n\n\tif eh.Shstrndx == 0 || int(eh.Shstrndx) >= len(shdrs) {\n\t\tfmt.Fprintf(os.Stderr, \"invalid Shstrndx %d\\n\", eh.Shstrndx)\n\t\tos.Exit(1)\n\t}\n\tshstr := shdrs[eh.Shstrndx]\n\tshstrTab := make([]byte, shstr.Size)\n\tif err := readAtFull(in, shstrTab, int64(shstr.Off)); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read .shstrtab: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tsecName := func(i int) string {\n\t\tif i < 0 || i >= len(shdrs) {\n\t\t\treturn \"<badsec>\"\n\t\t}\n\t\tn, err := cstr(shstrTab, shdrs[i].Name)\n\t\tif err != nil {\n\t\t\treturn \"<badname>\"\n\t\t}\n\t\treturn n\n\t}\n\n\t// Locate .dynsym and its associated string table via sh_link.\n\tdynsymIdx := -1\n\tfor i, sh := range shdrs {\n\t\tif sh.Type == SHT_DYNSYM {\n\t\t\tdynsymIdx = i\n\t\t\tbreak\n\t\t}\n\t}\n\tif d"]
