[103.571018, "i", "g malloc (sym idx %d)\\n\", mallocIdx)\n\t\tos.Exit(1)\n\t}\n\n\t// Ensure first 64 bytes unchanged.\n\tif !bytes.Equal(origPrefix, data[:64]) {\n\t\tfmt.Fprintf(os.Stderr, \"internal error: ELF header prefix (0..63) changed\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t// Write output.\n\tif err := os.WriteFile(outPath, data, 0755); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"write output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif err := os.Chmod(outPath, 0755); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"chmod output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"done: wrote %s (patched %d relocations)\\n\", outPath, patched)\n}\nEOF\n"]
