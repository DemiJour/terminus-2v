[103.570919, "i", "ynsymIdx < 0 {\n\t\tfmt.Fprintf(os.Stderr, \"missing .dynsym (SHT_DYNSYM)\\n\")\n\t\tos.Exit(1)\n\t}\n\tdynsym := shdrs[dynsymIdx]\n\tif dynsym.Entsize == 0 {\n\t\tfmt.Fprintf(os.Stderr, \".dynsym has zero Entsize\\n\")\n\t\tos.Exit(1)\n\t}\n\tif dynsym.Link == 0 || int(dynsym.Link) >= len(shdrs) {\n\t\tfmt.Fprintf(os.Stderr, \".dynsym has invalid sh_link %d\\n\", dynsym.Link)\n\t\tos.Exit(1)\n\t}\n\tdynstr := shdrs[dynsym.Link]\n\tif dynstr.Type != SHT_STRTAB {\n\t\tfmt.Fprintf(os.Stderr, \".dynsym sh_link does not point to STRTAB (got type %d)\\n\", dynstr.Type)\n\t\tos.Exit(1)\n\t}\n\n\tdynstrTab := make([]byte, dynstr.Size)\n\tif err := readAtFull(in, dynstrTab, int64(dynstr.Off)); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read .dynstr: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\t// Read dynsym entries\n\tif dynsym.Size%uint64(dynsym.Entsize) != 0 {\n\t\tfmt.Fprintf(os.Stderr, \".dynsym size not multiple of entsize\\n\")\n\t\tos.Exit(1)\n\t}\n\tnSyms := int(dynsym.Size / uint64(dynsym.Entsize))\n\tsymBuf := make([]byte, dynsym.Size)\n\tif err := readAtFull(in, symBuf, int64(dynsym.Off)); err != nil"]
[103.570959, "i", " {\n\t\tfmt.Fprintf(os.Stderr, \"read .dynsym: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tsyms := make([]elf64Sym, nSyms)\n\tfor i := 0; i < nSyms; i++ {\n\t\tstart := i * int(dynsym.Entsize)\n\t\t// We only support ELF64 sym size 24 bytes.\n\t\tif int(dynsym.Entsize) < 24 {\n\t\t\tfmt.Fprintf(os.Stderr, \"unsupported dynsym entsize %d\\n\", dynsym.Entsize)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvar s elf64Sym\n\t\tif err := binary.Read(bytes.NewReader(symBuf[start:start+24]), binary.LittleEndian, &s); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"parse dynsym[%d]: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tsyms[i] = s\n\t}\n\n\tnameToIndex := map[string]uint32{}\n\tfor i, s := range syms {\n\t\tn, err := cstr(dynstrTab, s.Name)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\t// Keep first occurrence; symbol resolution uses versioning too, but\n\t\t// for our harness we expect unique names.\n\t\tif _, ok := nameToIndex[n]; !ok {\n\t\t\tnameToIndex[n] = uint32(i)\n\t\t}\n\t}\n\n\tmallocIdx, ok := nameToIndex[\"malloc\"]\n\tif !ok {\n\t\tfmt.Fprintf(os.Stderr, \"missing symbol in .dynsym: malloc\\n\")\n\t\tos.Exit(1)\n\t}\n\twrapperIdx, "]
[103.570971, "i", "ok := nameToIndex[wrapper]\n\tif !ok {\n\t\tfmt.Fprintf(os.Stderr, \"missing symbol in .dynsym: %s\\n\", wrapper)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"dynsym: malloc idx=%d, %s idx=%d\\n\", mallocIdx, wrapper, wrapperIdx)\n\n\t// Load entire file into memory for patching.\n\tdata, err := os.ReadFile(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\torigPrefix := append([]byte(nil), data[:64]...)\n\n\tpatched := 0\n\t// Scan relocation sections (SHT_RELA). We only rewrite r_info sym index.\n\tfor si, sh := range shdrs {\n\t\tif sh.Type != SHT_RELA {\n\t\t\tcontinue\n\t\t}\n\t\tif sh.Entsize == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tif sh.Size%uint64(sh.Entsize) != 0 {\n\t\t\tcontinue\n\t\t}\n\t\tn := int(sh.Size / uint64(sh.Entsize))\n\t\tsecOff := int64(sh.Off)\n\t\tsecEnd := secOff + int64(sh.Size)\n\t\tif secOff < 0 || secEnd < secOff || secEnd > int64(len(data)) {\n\t\t\tfmt.Fprintf(os.Stderr, \"skip relocation section %d (%s): out of file bounds\\n\", si, secName(si))\n\t\t\tcontinue\n\t\t}\n\t\tsecBytes := data[secOff:secEnd]\n\n\t\t// Only support"]
[103.57098, "i", " ELF64 Rela size 24.\n\t\tif sh.Entsize < 24 {\n\t\t\tfmt.Fprintf(os.Stderr, \"skip relocation section %d (%s): entsize %d too small\\n\", si, secName(si), sh.Entsize)\n\t\t\tcontinue\n\t\t}\n\n\t\tfor i := 0; i < n; i++ {\n\t\t\tentOff := i * int(sh.Entsize)\n\t\t\tvar r elf64Rela\n\t\t\tif err := binary.Read(bytes.NewReader(secBytes[entOff:entOff+24]), binary.LittleEndian, &r); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"parse rela %s[%d]: %v\\n\", secName(si), i, err)\n\t\t\t\tos.Exit(1)\n\t\t\t}\n\t\t\toldSym := elf64RelaSym(r.Info)\n\t\t\ttyp := elf64RelaType(r.Info)\n\t\t\tif oldSym != mallocIdx {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tnewInfo := elf64RelaInfo(wrapperIdx, typ)\n\t\t\t// Patch r_info in-place at offset 8 within Rela.\n\t\t\tbinary.LittleEndian.PutUint64(secBytes[entOff+8:entOff+16], newInfo)\n\t\t\tpatched++\n\t\t\tfmt.Fprintf(os.Stderr, \"patched relocation: section=%s idx=%d r_offset=0x%x type=%d sym %d(malloc) -> %d(%s)\\n\",\n\t\t\t\tsecName(si), i, r.Off, typ, oldSym, wrapperIdx, wrapper)\n\t\t}\n\t}\n\n\tif patched == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"no applicable relocations found targetin"]
