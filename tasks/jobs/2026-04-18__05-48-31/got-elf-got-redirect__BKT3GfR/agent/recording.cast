[164.988162, "o", "package main\r\n\r\nimport (\r\n\"bytes\"\r\n\"encoding/binary\"\r\n\"errors\"\r\n\"fmt\"\r\n\"io\"\r\n\"os\"\r\n)\r\n\r\nconst (\r\nelfClass64 = 2\r\nelfData2LSB = 1\r\n\r\nshtRela = 4\r\n)\r\n\r\ntype ehdr64 struct {\r\nIdent     [16]byte\r\nType      uint16\r\nMachine   uint16\r\nVersion   uint32\r\nEntry     uint64\r\nPhoff     uint64\r\nShoff     uint64\r\nFlags     uint32\r\nEhsize    uint16\r\nPhentsize uint16\r\nPhnum     uint16\r\nShentsize uint16\r\nShnum     uint16\r\nShstrndx  uint16\r\n}\r\n\r\ntype shdr64 struct {\r\nName      uint32\r\nType      uint32\r\nFlags     uint64\r\nAddr      uint64\r\nOff       uint64\r\nSize      uint64\r\nLink      uint32\r\nInfo      uint32\r\nAddralign uint64\r\nEntsize   uint64\r\n"]
[164.988708, "o", "}\r\n"]
[164.988891, "o", "\r\ntype sym64 struct {\r\nName  uint32\r\nInfo  byte\r\nOther byte\r\nShndx uint16\r\nValue uint64\r\nSize  uint64\r\n}\r\n\r\ntype rela64 struct {\r\nOff  uint64\r\nInfo uint64\r\nAdd  int64\r\n}\r\n\r\nfunc elf64RSym(info uint64) uint32 { return uint32(info >> 32) }\r\nfunc elf64RType(info uint64) uint32 { return uint32(info & 0xffffffff) }\r\nfunc elf64RInfo(sym uint32, typ uint32) uint64 { return (uint64(sym) << 32) | uint64(typ) }\r\n\r\nfunc cStringFrom(b []byte, off uint32) string {\r\ni := int(off)\r\nif i < 0 || i >= len(b) {\r\nreturn \"\"\r\n}\r\nj := bytes.IndexByte(b[i:], 0)\r\nif j < 0 {\r\nreturn \"\"\r\n}\r\nreturn string(b[i : i+j])\r\n}\r\n\r\nfunc readAt(b []byte, off uint64, out any) error {\r\nif off > uint64(len(b)) {\r\nreturn io.ErrUnexpectedEOF\r\n}\r\nsz := binary.Size(out)\r\nif sz < 0 {\r\nreturn fmt.Errorf(\"unsupported binary.Size for %T\", out)\r\n}\r\nend := off + uint64(sz)\r\nif end > uint64(len(b)) {\r\nreturn io.ErrUnexpectedEOF\r\n}\r\nreturn binary.Read(bytes.NewReader(b[off:end]), binary.LittleEndian, out)\r\n}\r\n\r\nfunc writeUint64At(b []byte, off uint64, v uint64)"]
[164.988936, "o", " error {\r\nif off+8 > uint64(len(b)) {\r\n"]
[164.989206, "o", "return io.ErrUnexpectedEOF\r\n}\r\n"]
[164.989277, "o", "binary.LittleEndian.PutUint64(b[off:off+8], v)\r\nreturn nil\r\n}\r\n\r\nfunc main() {\r\nif len(os.Args) != 3 && len(os.Args) != 4 {\r\nfmt.Fprintf(os.Stderr, \"usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n\", os.Args[0])\r\nos.Exit(2)\r\n}\r\ninPath := os.Args[1]\r\noutPath := os.Args[2]\r\nwrapper := \"logged_malloc\"\r\nif len(os.Args) == 4 {\r\nwrapper = os.Args[3]\r\n}\r\n\r\nin, err := os.ReadFile(inPath)\r\nif err != nil {\r\nfmt.Fprintf(os.Stderr, \"got-patch: read input: %v\\n\", err)\r\nos.Exit(1)\r\n}\r\nif len(in) < 64 {\r\n"]
