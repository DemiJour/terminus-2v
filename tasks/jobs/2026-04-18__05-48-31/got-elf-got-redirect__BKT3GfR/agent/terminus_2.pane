package main

import (
	"bytes"
	"encoding/binary"
	"fmt"
	"io"
	"os"
)

const (
	elfClass64 = 2
	elfData2LSB = 1

	shtRela = 4
)

type ehdr64 struct {
	Ident     [16]byte
	Type      uint16
	Machine   uint16
	Version   uint32
	Entry     uint64
	Phoff     uint64
	Shoff     uint64
	Flags     uint32
	Ehsize    uint16
	Phentsize uint16
	Phnum     uint16
	Shentsize uint16
	Shnum     uint16
	Shstrndx  uint16
}

type shdr64 struct {
	Name      uint32
	Type      uint32
	Flags     uint64
	Addr      uint64
	Off       uint64
	Size      uint64
	Link      uint32
	Info      uint32
	Addralign uint64
	Entsize   uint64
}

type sym64 struct {
	Name  uint32
	Info  byte
	Other byte
	Shndx uint16
	Value uint64
	Size  uint64
}

type rela64 struct {
	Off  uint64
	Info uint64
	Add  int64
}

func elf64RSym(info uint64) uint32  { return uint32(info >> 32) }
func elf64RType(info uint64) uint32 { return uint32(info & 0xffffffff) }
func elf64RInfo(sym uint32, typ uint32) uint64 {
	return (uint64(sym) << 32) | uint64(typ)
}

func cStringFrom(b []byte, off uint32) string {
	i := int(off)
	if i < 0 || i >= len(b) {
		return ""
	}
	j := bytes.IndexByte(b[i:], 0)
	if j < 0 {
		return ""
	}
	return string(b[i : i+j])
}

func readAt(b []byte, off uint64, out any) error {
	if off > uint64(len(b)) {
		return io.ErrUnexpectedEOF
	}
	sz := binary.Size(out)
	if sz < 0 {
		return fmt.Errorf("unsupported binary.Size for %T", out)
	}
	end := off + uint64(sz)
	if end > uint64(len(b)) {
		return io.ErrUnexpectedEOF
	}
	return binary.Read(bytes.NewReader(b[off:end]), binary.LittleEndian, out)
}

func writeUint64At(b []byte, off uint64, v uint64) error {
	if off+8 > uint64(len(b)) {
		return io.ErrUnexpectedEOF
	}
	binary.LittleEndian.PutUint64(b[off:off+8], v)
	return nil
}

func writeFile0755(path string, data []byte) error {
	tmp := path + ".tmp"
	_ = os.Remove(tmp)
	if err := os.WriteFile(tmp, data, 0o755); err != nil {
		return err
	}
	if err := os.Rename(tmp, path); err != nil {
		_ = os.Remove(tmp)
		return err
	}
	return os.Chmod(path, 0o755)
}

func main() {
	if len(os.Args) != 3 && len(os.Args) != 4 {
		fmt.Fprintf(os.Stderr, "usage: %s <input_elf> <output_elf> [wrapper_symbol]\n", os.Args[0])
		os.Exit(2)
	}
	inPath := os.Args[1]
	outPath := os.Args[2]
	wrapper := "logged_malloc"
	if len(os.Args) == 4 {
		wrapper = os.Args[3]
	}

	in, err := os.ReadFile(inPath)
	if err != nil {
		fmt.Fprintf(os.Stderr, "got-patch: read input: %v\n", err)
		os.Exit(1)
	}
	if len(in) < 64 {
		fmt.Fprintf(os.Stderr, "got-patch: input too small to be ELF64\n")
		os.Exit(1)
	}

	var eh ehdr64
	if err := readAt(in, 0, &eh); err != nil {
		fmt.Fprintf(os.Stderr, "got-patch: parse ELF header: %v\n", err)
		os.Exit(1)
	}
	if string(eh.Ident[0:4]) != "\x7fELF" {
		fmt.Fprintf(os.Stderr, "got-patch: not an ELF file\n")
		os.Exit(1)
	}
	if eh.Ident[4] != elfClass64 {
		fmt.Fprintf(os.Stderr, "got-patch: expected ELFCLASS64, got %d\n", eh.Ident[4])
		os.Exit(1)
	}
	if eh.Ident[5] != elfData2LSB {
		fmt.Fprintf(os.Stderr, "got-patch: expected little-endian ELF (ELFDATA2LSB), got %d\n", eh.Ident[5])
		os.Exit(1)
	}
	if eh.Shentsize != uint16(binary.Size(shdr64{})) {
		fmt.Fprintf(os.Stderr, "got-patch: unexpected section header entry size: %d\n", eh.Shentsize)
		os.Exit(1)
	}
	if eh.Shoff == 0 || eh.Shnum == 0 {
		fmt.Fprintf(os.Stderr, "got-patch: missing section headers\n")
		os.Exit(1)
	}

	shdrs := make([]shdr64, eh.Shnum)
	for i := 0; i < int(eh.Shnum); i++ {
		off := eh.Shoff + uint64(i)*uint64(eh.Shentsize)
		if err := readAt(in, off, &shdrs[i]); err != nil {
			fmt.Fprintf(os.Stderr, "got-patch: read shdr[%d]: %v\n", i, err)
