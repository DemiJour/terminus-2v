rintf(os.Stderr, "got-patch: shstrtab out of range\n")
		os.Exit(1)
	}
	shstrBytes := in[shstr.Off : shstr.Off+shstr.Size]

	secName := func(idx int) string {
		if idx < 0 || idx >= len(shdrs) {
			return ""
		}
		return cStringFrom(shstrBytes, shdrs[idx].Name)
	}

	findSection := func(want string) *shdr64 {
		for i := range shdrs {
			if secName(i) == want {
				return &shdrs[i]
			}
		}
		return nil
	}

	dynsym := findSection(".dynsym")
	dynstr := findSection(".dynstr")
	if dynsym == nil || dynstr == nil {
		fmt.Fprintf(os.Stderr, "got-patch: missing .dynsym or .dynstr\n")
		os.Exit(1)
	}
	if dynsym.Entsize != uint64(binary.Size(sym64{})) {
		fmt.Fprintf(os.Stderr, "got-patch: unexpected .dynsym entsize=%d\n", dynsym.Entsize)
		os.Exit(1)
	}
	if dynsym.Off+dynsym.Size > uint64(len(in)) || dynstr.Off+dynstr.Size > uint64(len(in)) {
		fmt.Fprintf(os.Stderr, "got-patch: dynsym/dynstr out of range\n")
		os.Exit(1)
	}
	dynstrBytes := in[dynstr.Off : dynstr.Off+dynstr.Size]

	nSyms := int(dynsym.Size / dynsym.Entsize)
	symNames := make([]string, nSyms)
	for i := 0; i < nSyms; i++ {
		var s sym64
		off := dynsym.Off + uint64(i)*dynsym.Entsize
		if err := readAt(in, off, &s); err != nil {
			fmt.Fprintf(os.Stderr, "got-patch: read dynsym[%d]: %v\n", i, err)
			os.Exit(1)
		}
		symNames[i] = cStringFrom(dynstrBytes, s.Name)
	}

	mallocIdx := -1
	wrapperIdx := -1
	for i, n := range symNames {
		if n == "malloc" {
			mallocIdx = i
		}
		if n == wrapper {
			wrapperIdx = i
		}
	}
	if wrapperIdx < 0 {
		fmt.Fprintf(os.Stderr, "got-patch: wrapper symbol not found in .dynsym: %q\n", wrapper)
		os.Exit(1)
	}
	if mallocIdx < 0 {
		fmt.Fprintf(os.Stderr, "got-patch: target symbol not found in .dynsym: %q\n", "malloc")
		os.Exit(1)
	}

	out := make([]byte, len(in))
	copy(out, in)

	patched := 0
	for si, sh := range shdrs {
		if sh.Type != shtRela {
			continue
		}
		if sh.Entsize != uint64(binary.Size(rela64{})) {
			continue
		}
		if sh.Off+sh.Size > uint64(len(in)) {
			fmt.Fprintf(os.Stderr, "got-patch: relocation section %q out of range\n", secName(si))
			os.Exit(1)
		}
		n := int(sh.Size / sh.Entsize)
