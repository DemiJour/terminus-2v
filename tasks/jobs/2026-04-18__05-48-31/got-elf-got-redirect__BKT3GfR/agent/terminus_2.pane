	if patched == 0 {
		fmt.Fprintf(os.Stderr, "got-patch: no applicable relocations found targeting %q\n", "malloc")
		os.Exit(1)
	}
	if !bytes.Equal(in[:64], out[:64]) {
		fmt.Fprintf(os.Stderr, "got-patch: internal error: ELF header prefix (first 64 bytes) changed\n")
		os.Exit(1)
	}

	if err := writeFile0755(outPath, out); err != nil {
		fmt.Fprintf(os.Stderr, "got-patch: write output: %v\n", err)
		os.Exit(1)
	}
	fmt.Fprintf(os.Stderr, "got-patch: success: patched %d relocation(s); dynsym[%d]=malloc -> dynsym[%d]=%s\n",
		patched, mallocIdx, wrapperIdx, wrapper)
}
