[286.618582, "i", ".Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {\n\t\tfmt.Fprintf(os.Stderr, \"not an ELF file\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_CLASS] != ELFCLASS64 {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF class (need 64-bit)\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF endianness (need little-endian)\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Shoff == 0 || eh.Shnum == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"missing section headers; cannot patch\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tshdrs := make([]elf64Shdr, int(eh.Shnum))\n\tfor i := 0; i < int(eh.Shnum); i++ {\n\t\toff := int64(eh.Shoff) + int64(i)*int64(eh.Shentsize)\n\t\tif err := readStructAt(inF, off, binary.LittleEndian, &shdrs[i]); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"read section header %d: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t}\n\tif int(eh.Shstrndx) <= 0 || int(eh.Shstrndx) >= len(shdrs) {\n\t\tfmt.Fprintf(os.Stderr, \"invalid shstrndx: %d\\n\", eh.Shstrndx)\n\t\tos.Exit(1)\n\t}\n\tshstr := shdrs[int(eh.Shstrndx)]\n\n\tsecs := make([]se"]
[286.618677, "o", "> [wrapper_symbol]\\n\", os.Args[0])\r\n\t}\r\n\tflag.Parse()\r\n\targs := flag.Args()\r\n\tif len(args) != 2 && len(args) != 3 {\r\n\t\tflag.Usage()\r\n\t\tos.Exit(2)\r\n\t}\r\n\tinPath := args[0]\r\n\toutPath := args[1]\r\n\twrapper := \"logged_malloc\"\r\n\tif len(args) == 3 {\r\n\t\twrapper = args[2]\r\n\t}\r\n\r\n\tinF, err := os.Open(inPath)\r\n\tif err != nil {\r\n\t\tfmt.Fprintf(os.Stderr, \"open input: %v\\n\", err)\r\n\t\tos.Exit(1)\r\n\t}\r\n\tdefer inF.Close()\r\n\r\n\tvar eh elf64Ehdr\r\n\tif err := readStructAt(inF, 0, binary.LittleEndian, &eh); err != nil {\r\n\t\tfmt.Fprintf(os.Stderr, \"read ELF header: %v\\n\", err)\r\n\t\tos.Exit(1)\r\n\t}\r\n\tif eh.Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {\r\n\t\tfmt.Fprintf(os.Stderr, \"not an ELF file\\n\")\r\n\t\tos.Exit(1)\r\n\t}\r\n\tif eh.Ident[EI_CLASS] != ELFCLASS64 {\r\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF class (need 64-bit)\\n\")\r\n\t\tos.Exit(1)\r\n\t}\r\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\r\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF endianness (need little-endian)\\n\")\r\n\t\tos.Exit(1)\r\n\t}\r\n\tif eh.Shoff == 0 || eh.Shnum"]
[286.618685, "i", "ction, len(shdrs))\n\tfor i := range shdrs {\n\t\tname, err := readCStringFrom(inF, int64(shstr.Off), int64(shstr.Size), shdrs[i].Name)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"read section name %d: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tsecs[i] = section{h: shdrs[i], name: name, idx: i}\n\t}\n\n\tvar dynsymSec *section\n\tfor i := range secs {\n\t\tif secs[i].h.Type == SHT_DYNSYM || secs[i].name == \".dynsym\" {\n\t\t\tdynsymSec = &secs[i]\n\t\t\tbreak\n\t\t}\n\t}\n\tif dynsymSec == nil {\n\t\tfmt.Fprintf(os.Stderr, \"missing .dynsym; cannot patch\\n\")\n\t\tos.Exit(1)\n\t}\n\tif dynsymSec.h.Link >= uint32(len(secs)) {\n\t\tfmt.Fprintf(os.Stderr, \"dynsym sh_link out of range: %d\\n\", dynsymSec.h.Link)\n\t\tos.Exit(1)\n\t}\n\tdynstrSec := &secs[dynsymSec.h.Link]\n\tif dynstrSec.h.Type != SHT_STRTAB {\n\t\tfmt.Fprintf(os.Stderr, \"warning: dynsym sh_link does not point to STRTAB (type=%d name=%s)\\n\", dynstrSec.h.Type, dynstrSec.name)\n\t}\n\n\t// Find dynsym indices for malloc and wrapper.\n\tif dynsymSec.h.Entsize == 0 {\n\t\tdynsymSec.h.Entsize = uint64(binary.Size(elf64Sym{}))\n"]
