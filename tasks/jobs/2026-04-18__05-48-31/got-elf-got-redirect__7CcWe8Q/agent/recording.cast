[286.618321, "i", "cat > /app/cmd/got-patch/main.go <<'EOF'\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/binary\"\n\t\"errors\"\n\t\"flag\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n)\n\nconst (\n\tEI_CLASS = 4\n\tEI_DATA  = 5\n\n\tELFCLASS64  = 2\n\tELFDATA2LSB = 1\n\n\tSHT_STRTAB = 3\n\tSHT_RELA   = 4\n\tSHT_DYNSYM = 11\n)\n\ntype elf64Ehdr struct {\n\tIdent     [16]byte\n\tType      uint16\n\tMachine   uint16\n\tVersion   uint32\n\tEntry     uint64\n\tPhoff     uint64\n\tShoff     uint64\n\tFlags     uint32\n\tEhsize    uint16\n\tPhentsize uint16\n\tPhnum     uint16\n\tShentsize uint16\n\tShnum     uint16\n\tShstrndx  uint16\n}\n\ntype elf64Shdr struct {\n\tName      uint32\n\tType      uint32\n\tFlags     uint64\n\tAddr      uint64\n\tOff       uint64\n\tSize      uint64\n\tLink      uint32\n\tInfo      uint32\n\tAddralign uint64\n\tEntsize   uint64\n}\n\ntype elf64Sym struct {\n\tName  uint32\n\tInfo  uint8\n\tOther uint8\n\tShndx uint16\n\tValue uint64\n\tSize  uint64\n}\n\ntype elf64Rela struct {\n\tOff    uint64\n\tInfo   uint64\n\tAddend int64\n}\n\nfunc elf64RSym(info uint64) uint32  { return uint32(info >> 32) }\nfunc elf64RType(info uint64) uint32"]
[286.618409, "o", "cat > /app/cmd/got-patch/main.go <<'EOF'\r\npackage main\r\n\r\nimport (\r\n\t\"bytes\"\r\n\t\"encoding/binary\"\r\n\t\"errors\"\r\n\t\"flag\"\r\n\t\"fmt\"\r\n\t\"io\"\r\n\t\"os\"\r\n)\r\n\r\nconst (\r\n\tEI_CLASS = 4\r\n\tEI_DATA  = 5\r\n\r\n\tELFCLASS64  = 2\r\n\tELFDATA2LSB = 1\r\n\r\n\tSHT_STRTAB = 3\r\n\tSHT_RELA   = 4\r\n\tSHT_DYNSYM = 11\r\n)\r\n\r\ntype elf64Ehdr struct {\r\n\tIdent     [16]byte\r\n\tType      uint16\r\n\tMachine   uint16\r\n\tVersion   uint32\r\n\tEntry     uint64\r\n\tPhoff     uint64\r\n\tShoff     uint64\r\n\tFlags     uint32\r\n\tEhsize    uint16\r\n\tPhentsize uint16\r\n\tPhnum     uint16\r\n\tShentsize uint16\r\n\tShnum     uint16\r\n\tShstrndx  uint16\r\n}\r\n\r\ntype elf64Shdr struct {\r\n\tName      uint32\r\n\tType      uint32\r\n\tFlags     uint64\r\n\tAddr      uint64\r\n\tOff       uint64\r\n\tSize      uint64\r\n\tLink      uint32\r\n\tInfo      uint32\r\n\tAddralign uint64\r\n\tEntsize   uint64\r\n}\r\n\r\ntype elf64Sym struct {\r\n\tName  uint32\r\n\tInfo  uint8\r\n\tOther uint8\r\n\tShndx uint16\r\n\tValue uint64\r\n\tSize  uint64\r\n}\r\n\r\ntype elf64Rela struct {\r\n\tOff    uint64\r\n\tInfo   uint64\r\n\tAddend int64\r\n}\r\n\r\nfunc elf64RSym(info uint64) uin"]
[286.618471, "i", " { return uint32(info & 0xffffffff) }\nfunc elf64RInfo(sym uint32, typ uint32) uint64 {\n\treturn (uint64(sym) << 32) | uint64(typ)\n}\n\nfunc readAtFull(r io.ReaderAt, off int64, b []byte) error {\n\tn, err := r.ReadAt(b, off)\n\tif err != nil && !errors.Is(err, io.EOF) {\n\t\treturn err\n\t}\n\tif n != len(b) {\n\t\treturn io.ErrUnexpectedEOF\n\t}\n\treturn nil\n}\n\nfunc readStructAt[T any](r io.ReaderAt, off int64, order binary.ByteOrder, out *T) error {\n\tsz := binary.Size(*out)\n\tbuf := make([]byte, sz)\n\tif err := readAtFull(r, off, buf); err != nil {\n\t\treturn err\n\t}\n\treturn binary.Read(bytes.NewReader(buf), order, out)\n}\n\nfunc readCStringFrom(r io.ReaderAt, base int64, size int64, off uint32) (string, error) {\n\tstart := int64(off)\n\tif start < 0 || start >= size {\n\t\treturn \"\", fmt.Errorf(\"string offset out of range: %d (size %d)\", start, size)\n\t}\n\tvar out []byte\n\tpos := start\n\tfor {\n\t\tif pos >= size {\n\t\t\treturn \"\", fmt.Errorf(\"unterminated string at offset %d\", start)\n\t\t}\n\t\tchunk := make([]byte, 256)\n\t\tremain := size - pos\n\t\tif rem"]
[286.618482, "o", "t32  { return uint32(info >> 32) }\r\nfunc elf64RType(info uint64) uint32 { return uint32(info & 0xffffffff) }\r\nfunc elf64RInfo(sym uint32, typ uint32) uint64 {\r\n\treturn (uint64(sym) << 32) | uint64(typ)\r\n}\r\n\r\nfunc readAtFull(r io.ReaderAt, off int64, b []byte) error {\r\n\tn, err := r.ReadAt(b, off)\r\n\tif err != nil && !errors.Is(err, io.EOF) {\r\n\t\treturn err\r\n\t}\r\n\tif n != len(b) {\r\n\t\treturn io.ErrUnexpectedEOF\r\n\t}\r\n\treturn nil\r\n}\r\n\r\nfunc readStructAt[T any](r io.ReaderAt, off int64, order binary.ByteOrder, out *T) error {\r\n\tsz := binary.Size(*out)\r\n\tbuf := make([]byte, sz)\r\n\tif err := readAtFull(r, off, buf); err != nil {\r\n\t\treturn err\r\n\t}\r\n\treturn binary.Read(bytes.NewReader(buf), order, out)\r\n}\r\n\r\nfunc readCStringFrom(r io.ReaderAt, base int64, size int64, off uint32) (string, error) {\r\n\tstart := int64(off)\r\n\tif start < 0 || start >= size {\r\n\t\treturn \"\", fmt.Errorf(\"string offset out of range: %d (size %d)\", start, size)\r\n\t}\r\n\tvar out []byte\r\n\tpos := start\r\n\tfor {\r\n\t\tif pos >= size {\r\n\t\t\treturn \"\", fmt.Errorf(\"u"]
[286.618511, "i", "ain < int64(len(chunk)) {\n\t\t\tchunk = chunk[:remain]\n\t\t}\n\t\tif err := readAtFull(r, base+pos, chunk); err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\tif i := bytes.IndexByte(chunk, 0); i >= 0 {\n\t\t\tout = append(out, chunk[:i]...)\n\t\t\treturn string(out), nil\n\t\t}\n\t\tout = append(out, chunk...)\n\t\tpos += int64(len(chunk))\n\t}\n}\n\ntype section struct {\n\th    elf64Shdr\n\tname string\n\tidx  int\n}\n\nfunc main() {\n\tflag.Usage = func() {\n\t\tfmt.Fprintf(os.Stderr, \"usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n\", os.Args[0])\n\t}\n\tflag.Parse()\n\targs := flag.Args()\n\tif len(args) != 2 && len(args) != 3 {\n\t\tflag.Usage()\n\t\tos.Exit(2)\n\t}\n\tinPath := args[0]\n\toutPath := args[1]\n\twrapper := \"logged_malloc\"\n\tif len(args) == 3 {\n\t\twrapper = args[2]\n\t}\n\n\tinF, err := os.Open(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"open input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer inF.Close()\n\n\tvar eh elf64Ehdr\n\tif err := readStructAt(inF, 0, binary.LittleEndian, &eh); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read ELF header: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif eh"]
