[95.45076, "i", "cat > /app/cmd/got-patch/main.go <<'EOF'\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/binary\"\n\t\"errors\"\n\t\"flag\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n)\n\n// Minimal ELF64 little-endian layout code (no debug/elf).\n\nconst (\n\tEI_CLASS = 4\n\tEI_DATA  = 5\n\n\tELFCLASS64 = 2\n\tELFDATA2LSB = 1\n\n\tSHT_NULL   = 0\n\tSHT_SYMTAB = 2\n\tSHT_STRTAB = 3\n\tSHT_RELA   = 4\n\tSHT_DYNSYM = 11\n)\n\ntype elf64Ehdr struct {\n\tIdent     [16]byte\n\tType      uint16\n\tMachine   uint16\n\tVersion   uint32\n\tEntry     uint64\n\tPhoff     uint64\n\tShoff     uint64\n\tFlags     uint32\n\tEhsize    uint16\n\tPhentsize uint16\n\tPhnum     uint16\n\tShentsize uint16\n\tShnum     uint16\n\tShstrndx  uint16\n}\n\ntype elf64Shdr struct {\n\tName      uint32\n\tType      uint32\n\tFlags     uint64\n\tAddr      uint64\n\tOff       uint64\n\tSize      uint64\n\tLink      uint32\n\tInfo      uint32\n\tAddralign uint64\n\tEntsize   uint64\n}\n\ntype elf64Sym struct {\n\tName  uint32\n\tInfo  uint8\n\tOther uint8\n\tShndx uint16\n\tValue uint64\n\tSize  uint64\n}\n\ntype elf64Rela struct {\n\tOff    uint64\n\tInfo   uint64\n\tAddend int64\n}\n\nfunc elf64"]
[95.450827, "i", "RSym(info uint64) uint32  { return uint32(info >> 32) }\nfunc elf64RType(info uint64) uint32 { return uint32(info & 0xffffffff) }\nfunc elf64RInfo(sym uint32, typ uint32) uint64 {\n\treturn (uint64(sym) << 32) | uint64(typ)\n}\n\nfunc readAtFull(r io.ReaderAt, off int64, b []byte) error {\n\tn, err := r.ReadAt(b, off)\n\tif err != nil && !errors.Is(err, io.EOF) {\n\t\treturn err\n\t}\n\tif n != len(b) {\n\t\treturn io.ErrUnexpectedEOF\n\t}\n\treturn nil\n}\n\nfunc readStructAt[T any](r io.ReaderAt, off int64, order binary.ByteOrder, out *T) error {\n\tsz := binary.Size(*out)\n\tbuf := make([]byte, sz)\n\tif err := readAtFull(r, off, buf); err != nil {\n\t\treturn err\n\t}\n\treturn binary.Read(bytes.NewReader(buf), order, out)\n}\n\nfunc readCStringFrom(r io.ReaderAt, base int64, size int64, off uint32) (string, error) {\n\tstart := int64(off)\n\tif start < 0 || start >= size {\n\t\treturn \"\", fmt.Errorf(\"string offset out of range: %d (size %d)\", start, size)\n\t}\n\t// Read in small chunks until NUL or end.\n\tvar out []byte\n\tpos := start\n\tfor {\n\t\tif pos >= size "]
[95.45085, "i", "{\n\t\t\treturn \"\", fmt.Errorf(\"unterminated string at offset %d\", start)\n\t\t}\n\t\tchunk := make([]byte, 256)\n\t\tremain := size - pos\n\t\tif remain < int64(len(chunk)) {\n\t\t\tchunk = chunk[:remain]\n\t\t}\n\t\tif err := readAtFull(r, base+pos, chunk); err != nil {\n\t\t\treturn \"\", err\n\t\t}\n\t\tif i := bytes.IndexByte(chunk, 0); i >= 0 {\n\t\t\tout = append(out, chunk[:i]...)\n\t\t\treturn string(out), nil\n\t\t}\n\t\tout = append(out, chunk...)\n\t\tpos += int64(len(chunk))\n\t}\n}\n\ntype section struct {\n\th elf64Shdr\n\tname string\n\tidx  int\n}\n\nfunc main() {\n\tflag.Usage = func() {\n\t\tfmt.Fprintf(os.Stderr, \"usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n\", os.Args[0])\n\t}\n\tflag.Parse()\n\targs := flag.Args()\n\tif len(args) != 2 && len(args) != 3 {\n\t\tflag.Usage()\n\t\tos.Exit(2)\n\t}\n\tinPath := args[0]\n\toutPath := args[1]\n\twrapper := \"logged_malloc\"\n\tif len(args) == 3 {\n\t\twrapper = args[2]\n\t}\n\n\tinF, err := os.Open(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"open input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer inF.Close()\n\n\t// Read ELF header.\n\tvar eh elf64Eh"]
[95.450869, "i", "dr\n\tif err := readStructAt(inF, 0, binary.LittleEndian, &eh); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read ELF header: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {\n\t\tfmt.Fprintf(os.Stderr, \"not an ELF file\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_CLASS] != ELFCLASS64 {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF class (need 64-bit)\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\n\t\tfmt.Fprintf(os.Stderr, \"unsupported ELF endianness (need little-endian)\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Shoff == 0 || eh.Shnum == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"missing section headers; cannot patch\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t// Read all section headers.\n\tif eh.Shentsize == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"invalid section header entry size\\n\")\n\t\tos.Exit(1)\n\t}\n\tshdrs := make([]elf64Shdr, int(eh.Shnum))\n\tfor i := 0; i < int(eh.Shnum); i++ {\n\t\toff := int64(eh.Shoff) + int64(i)*int64(eh.Shentsize)\n\t\tif err := readStructAt(inF, off, binary.LittleEndian, &shdrs[i]); err != ni"]
[95.45115, "i", "l {\n\t\t\tfmt.Fprintf(os.Stderr, \"read section header %d: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t}\n\tif int(eh.Shstrndx) <= 0 || int(eh.Shstrndx) >= len(shdrs) {\n\t\tfmt.Fprintf(os.Stderr, \"invalid shstrndx: %d\\n\", eh.Shstrndx)\n\t\tos.Exit(1)\n\t}\n\tshstr := shdrs[int(eh.Shstrndx)]\n\n\tsecs := make([]section, len(shdrs))\n\tfor i := range shdrs {\n\t\tname, err := readCStringFrom(inF, int64(shstr.Off), int64(shstr.Size), shdrs[i].Name)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"read section name %d: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tsecs[i] = section{h: shdrs[i], name: name, idx: i}\n\t}\n\n\t// Locate dynsym and dynstr.\n\tvar dynsymSec *section\n\tfor i := range secs {\n\t\tif secs[i].h.Type == SHT_DYNSYM || secs[i].name == \".dynsym\" {\n\t\t\t// prefer actual dynsym type, but accept name match\n\t\t\tdynsymSec = &secs[i]\n\t\t\tbreak\n\t\t}\n\t}\n\tif dynsymSec == nil {\n\t\tfmt.Fprintf(os.Stderr, \"missing .dynsym; cannot patch PLT/GOT relocations\\n\")\n\t\tos.Exit(1)\n\t}\n\tif dynsymSec.h.Link >= uint32(len(secs)) {\n\t\tfmt.Fprintf(os.Stderr, \"dynsym sh_link out of ra"]
