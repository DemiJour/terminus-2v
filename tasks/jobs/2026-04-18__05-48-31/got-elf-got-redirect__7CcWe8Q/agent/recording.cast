[286.618699, "i", "\t}\n\tcountSyms := int(dynsymSec.h.Size / dynsymSec.h.Entsize)\n\tvar mallocIdx, wrapperIdx uint32\n\tfor i := 0; i < countSyms; i++ {\n\t\tvar sym elf64Sym\n\t\toff := int64(dynsymSec.h.Off) + int64(i)*int64(dynsymSec.h.Entsize)\n\t\tif err := readStructAt(inF, off, binary.LittleEndian, &sym); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"read dynsym[%d]: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tname, err := readCStringFrom(inF, int64(dynstrSec.h.Off), int64(dynstrSec.h.Size), sym.Name)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"read dynstr for dynsym[%d]: %v\\n\", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tif name == \"malloc\" {\n\t\t\tmallocIdx = uint32(i)\n\t\t}\n\t\tif name == wrapper {\n\t\t\twrapperIdx = uint32(i)\n\t\t}\n\t}\n\tif wrapperIdx == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"wrapper symbol not found in .dynsym: %s\\n\", wrapper)\n\t\tos.Exit(1)\n\t}\n\tif mallocIdx == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"symbol not found in .dynsym: malloc\\n\")\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(os.Stderr, \"dynsym: malloc index=%d, %s index=%d\\n\", mallocIdx, wrapper, wrapperIdx)\n\n\t// Create output by byt"]
