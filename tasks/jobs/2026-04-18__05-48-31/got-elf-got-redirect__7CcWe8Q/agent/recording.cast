[497.51202, "i", " inHdr); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read input[0:64]: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif err := readAtFull(outF, 0, outHdr); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"read output[0:64]: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !bytes.Equal(inHdr, outHdr) {\n\t\tfmt.Fprintf(os.Stderr, \"internal error: output differs in first 64 bytes\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t// Patch all SHT_RELA sections that reference .dynsym via sh_link.\n\tpatched := 0\n\tfor i := range secs {\n\t\ts := &secs[i]\n\t\tif s.h.Type != SHT_RELA {\n\t\t\tcontinue\n\t\t}\n\t\tif s.h.Link != uint32(dynsymSec.idx) {\n\t\t\tcontinue\n\t\t}\n\t\tif s.h.Entsize == 0 {\n\t\t\ts.h.Entsize = uint64(binary.Size(elf64Rela{}))\n\t\t}\n\t\tn := int(s.h.Size / s.h.Entsize)\n\t\tfor j := 0; j < n; j++ {\n\t\t\tvar rela elf64Rela\n\t\t\trecOff := int64(s.h.Off) + int64(j)*int64(s.h.Entsize)\n\t\t\tif err := readStructAt(outF, recOff, binary.LittleEndian, &rela); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"read rela %s[%d]: %v\\n\", s.name, j, err)\n\t\t\t\tos.Exit(1)\n\t\t\t}\n\t\t\tsym := elf64RSym(rela.Info)\n\t\t\ttyp := elf64RType(rela.Info"]
