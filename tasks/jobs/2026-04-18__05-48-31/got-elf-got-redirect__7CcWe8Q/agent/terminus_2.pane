package main

import (
	"bytes"
	"encoding/binary"
	"errors"
	"flag"
	"fmt"
	"io"
	"os"
)

const (
	EI_CLASS = 4
	EI_DATA  = 5

	ELFCLASS64  = 2
	ELFDATA2LSB = 1

	SHT_STRTAB = 3
	SHT_RELA   = 4
	SHT_DYNSYM = 11
)

type elf64Ehdr struct {
	Ident     [16]byte
	Type      uint16
	Machine   uint16
	Version   uint32
	Entry     uint64
	Phoff     uint64
	Shoff     uint64
	Flags     uint32
	Ehsize    uint16
	Phentsize uint16
	Phnum     uint16
	Shentsize uint16
	Shnum     uint16
	Shstrndx  uint16
}

type elf64Shdr struct {
	Name      uint32
	Type      uint32
	Flags     uint64
	Addr      uint64
	Off       uint64
	Size      uint64
	Link      uint32
	Info      uint32
	Addralign uint64
	Entsize   uint64
}

type elf64Sym struct {
	Name  uint32
	Info  uint8
	Other uint8
	Shndx uint16
	Value uint64
	Size  uint64
}

type elf64Rela struct {
	Off    uint64
	Info   uint64
	Addend int64
}

func elf64RSym(info uint64) uint32  { return uint32(info >> 32) }
func elf64RType(info uint64) uint32 { return uint32(info & 0xffffffff) }
func elf64RInfo(sym uint32, typ uint32) uint64 {
	return (uint64(sym) << 32) | uint64(typ)
}

func readAtFull(r io.ReaderAt, off int64, b []byte) error {
	n, err := r.ReadAt(b, off)
	if err != nil && !errors.Is(err, io.EOF) {
		return err
	}
	if n != len(b) {
		return io.ErrUnexpectedEOF
	}
	return nil
}

func readStructAt[T any](r io.ReaderAt, off int64, order binary.ByteOrder, out *T) error {
	sz := binary.Size(*out)
	buf := make([]byte, sz)
	if err := readAtFull(r, off, buf); err != nil {
		return err
	}
	return binary.Read(bytes.NewReader(buf), order, out)
}

func readCStringFrom(r io.ReaderAt, base int64, size int64, off uint32) (string, error) {
	start := int64(off)
	if start < 0 || start >= size {
		return "", fmt.Errorf("string offset out of range: %d (size %d)", start, size)
	}
	var out []byte
	pos := start
	for {
		if pos >= size {
			return "", fmt.Errorf("unterminated string at offset %d", start)
		}
		chunk := make([]byte, 256)
		remain := size - pos
		if remain < int64(len(chunk)) {
			chunk = chunk[:remain]
		}
		if err := readAtFull(r, base+pos, chunk); err != nil {
			return "", err
		}
		if i := bytes.IndexByte(chunk, 0); i >= 0 {
			out = append(out, chunk[:i]...)
			return string(out), nil
		}
		out = append(out, chunk...)
		pos += int64(len(chunk))
	}
}

type section struct {
	h    elf64Shdr
	name string
	idx  int
}

func main() {
	flag.Usage = func() {
		fmt.Fprintf(os.Stderr, "usage: %s <input_elf> <output_elf> [wrapper_symbol]\n", os.Args[0])
	}
	flag.Parse()
	args := flag.Args()
	if len(args) != 2 && len(args) != 3 {
		flag.Usage()
		os.Exit(2)
	}
	inPath := args[0]
	outPath := args[1]
	wrapper := "logged_malloc"
	if len(args) == 3 {
		wrapper = args[2]
	}

	inF, err := os.Open(inPath)
	if err != nil {
		fmt.Fprintf(os.Stderr, "open input: %v\n", err)
		os.Exit(1)
	}
	defer inF.Close()

	var eh elf64Ehdr
	if err := readStructAt(inF, 0, binary.LittleEndian, &eh); err != nil {
		fmt.Fprintf(os.Stderr, "read ELF header: %v\n", err)
		os.Exit(1)
	}
	if eh.Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {
		fmt.Fprintf(os.Stderr, "not an ELF file\n")
		os.Exit(1)
	}
	if eh.Ident[EI_CLASS] != ELFCLASS64 {
		fmt.Fprintf(os.Stderr, "unsupported ELF class (need 64-bit)\n")
		os.Exit(1)
	}
	if eh.Ident[EI_DATA] != ELFDATA2LSB {
		fmt.Fprintf(os.Stderr, "unsupported ELF endianness (need little-endian)\n")
		os.Exit(1)
	}
	if eh.Shoff == 0 || eh.Shnum == 0 {
		fmt.Fprintf(os.Stderr, "missing section headers; cannot patch\n")
		os.Exit(1)
	}

	// Read all section headers.
	shdrs := make([]elf64Shdr, int(eh.Shnum))
	for i := 0; i < int(eh.Shnum); i++ {
		off := int64(eh.Shoff) + int64(i)*int64(eh.Shentsize)
		if err := readStructAt(inF, off, binary.LittleEndian, &shdrs[i]); err != nil {
			fmt.Fprintf(os.Stderr, "read section header %d: %v\n", i, err)
			os.Exit(1)
		}
	}
Selecting previously unselected package golang-1.19-go.
Preparing to unpack .../golang-1.19-go_1.19.8-2_amd64.deb ...
Unpacking golang-1.19-go (1.19.8-2) ...
Selecting previously unselected package golang-src.
Preparing to unpack .../golang-src_2%3a1.19~1_all.deb ...
Unpacking golang-src (2:1.19~1) ...
Selecting previously unselected package golang-go:amd64.
Preparing to unpack .../golang-go_2%3a1.19~1_amd64.deb ...
Unpacking golang-go:amd64 (2:1.19~1) ...
	if int(eh.Shstrndx) <= 0 || int(eh.Shstrndx) >= len(shdrs) {
		fmt.Fprintf(os.Stderr, "invalid shstrndx: %d\n", eh.Shstrndx)
		os.Exit(1)
	}
	shstr := shdrs[int(eh.Shstrndx)]

	secs := make([]section, len(shdrs))
	for i := range shdrs {
		name, err := readCStringFrom(inF, int64(shstr.Off), int64(shstr.Size), shdrs[i].Name)
		if err != nil {
			fmt.Fprintf(os.Stderr, "read section name %d: %v\n", i, err)
			os.Exit(1)
		}
		secs[i] = section{h: shdrs[i], name: name, idx: i}
	}

	// Locate .dynsym and its linked string table.
	var dynsymSec *section
	for i := range secs {
		if secs[i].h.Type == SHT_DYNSYM || secs[i].name == ".dynsym" {
			dynsymSec = &secs[i]
			break
		}
	}
	if dynsymSec == nil {
		fmt.Fprintf(os.Stderr, "missing .dynsym; cannot patch\n")
		os.Exit(1)
	}
	if dynsymSec.h.Link >= uint32(len(secs)) {
		fmt.Fprintf(os.Stderr, "dynsym sh_link out of range: %d\n", dynsymSec.h.Link)
		os.Exit(1)
	}
	dynstrSec := &secs[dynsymSec.h.Link]
	if dynstrSec.h.Type != SHT_STRTAB {
		fmt.Fprintf(os.Stderr, "warning: dynsym sh_link does not point to STRTAB (type=%d name=%s)\n", dynstrSec.h.Type, dynstrSec.name)
	}

	// Find dynsym indices for malloc and wrapper symbol.
	if dynsymSec.h.Entsize == 0 {
		dynsymSec.h.Entsize = uint64(binary.Size(elf64Sym{}))
	}
	countSyms := int(dynsymSec.h.Size / dynsymSec.h.Entsize)
	var mallocIdx, wrapperIdx uint32
	for i := 0; i < countSyms; i++ {
		var sym elf64Sym
		off := int64(dynsymSec.h.Off) + int64(i)*int64(dynsymSec.h.Entsize)
		if err := readStructAt(inF, off, binary.LittleEndian, &sym); err != nil {
			fmt.Fprintf(os.Stderr, "read dynsym[%d]: %v\n", i, err)
			os.Exit(1)
		}
		name, err := readCStringFrom(inF, int64(dynstrSec.h.Off), int64(dynstrSec.h.Size), sym.Name)
		if err != nil {
			fmt.Fprintf(os.Stderr, "read dynstr for dynsym[%d]: %v\n", i, err)
			os.Exit(1)
		}
		if name == "malloc" {
			mallocIdx = uint32(i)
		}
		if name == wrapper {
			wrapperIdx = uint32(i)
		}
	}
	if wrapperIdx == 0 {
		fmt.Fprintf(os.Stderr, "wrapper symbol not found in .dynsym: %s\n", wrapper)
		os.Exit(1)
	}
	if mallocIdx == 0 {
		fmt.Fprintf(os.Stderr, "symbol not found in .dynsym: malloc\n")
		os.Exit(1)
	}
	fmt.Fprintf(os.Stderr, "dynsym: malloc index=%d, %s index=%d\n", mallocIdx, wrapper, wrapperIdx)

	// Create output by copying input byte-for-byte.
	inInfo, err := inF.Stat()
	if err != nil {
		fmt.Fprintf(os.Stderr, "stat input: %v\n", err)
		os.Exit(1)
	}
	if _, err := inF.Seek(0, 0); err != nil {
		fmt.Fprintf(os.Stderr, "seek input: %v\n", err)
		os.Exit(1)
	}
	outF, err := os.OpenFile(outPath, os.O_CREATE|os.O_TRUNC|os.O_RDWR, 0755)
	if err != nil {
		fmt.Fprintf(os.Stderr, "create output: %v\n", err)
		os.Exit(1)
	}
	defer outF.Close()
	if _, err := io.Copy(outF, inF); err != nil {
		fmt.Fprintf(os.Stderr, "copy input->output: %v\n", err)
		os.Exit(1)
	}
	if err := outF.Truncate(inInfo.Size()); err != nil {
		fmt.Fprintf(os.Stderr, "truncate output: %v\n", err)
		os.Exit(1)
	}

	// Verify first 64 bytes unchanged.
	inHdr := make([]byte, 64)
	outHdr := make([]byte, 64)
	inF2, err := os.Open(inPath)
	if err != nil {
		fmt.Fprintf(os.Stderr, "open input for verify: %v\n", err)
		os.Exit(1)
	}
	defer inF2.Close()
	if err := readAtFull(inF2, 0, inHdr); err != nil {
		fmt.Fprintf(os.Stderr, "read input[0:64]: %v\n", err)
		os.Exit(1)
	}
	if err := readAtFull(outF, 0, outHdr); err != nil {
		fmt.Fprintf(os.Stderr, "read output[0:64]: %v\n", err)
		os.Exit(1)
	}
	if !bytes.Equal(inHdr, outHdr) {
		fmt.Fprintf(os.Stderr, "internal error: output differs in first 64 bytes\n")
		os.Exit(1)
	}

	// Patch all SHT_RELA sections that reference .dynsym via sh_link.
	patched := 0
	for i := range secs {
		s := &secs[i]
		if s.h.Type != SHT_RELA {
			continue
		}
		if s.h.Link != uint32(dynsymSec.idx) {
			continue
		}
		if s.h.Entsize == 0 {
			s.h.Entsize = uint64(binary.Size(elf64Rela{}))
		}
		n := int(s.h.Size / s.h.Entsize)
		for j := 0; j < n; j++ {
			var rela elf64Rela
			recOff := int64(s.h.Off) + int64(j)*int64(s.h.Entsize)
			if err := readStructAt(outF, recOff, binary.LittleEndian, &rela); err != nil {
				fmt.Fprintf(os.Stderr, "read rela %s[%d]: %v\n", s.name, j, err)
				os.Exit(1)
			}
			sym := elf64RSym(rela.Info)
			typ := elf64RType(rela.Info)
			if sym != mallocIdx {
				continue
			}
			oldInfo := rela.Info
			rela.Info = elf64RInfo(wrapperIdx, typ)

			var buf bytes.Buffer
			if err := binary.Write(&buf, binary.LittleEndian, &rela); err != nil {
				fmt.Fprintf(os.Stderr, "encode rela: %v\n", err)
				os.Exit(1)
			}
			if _, err := outF.WriteAt(buf.Bytes(), recOff); err != nil {
				fmt.Fprintf(os.Stderr, "write rela %s[%d]: %v\n", s.name, j, err)
				os.Exit(1)
			}

			patched++
			fmt.Fprintf(os.Stderr, "patched relocation: section=%s idx=%d file_off=0x%x r_offset=0x%x r_type=%d r_sym:%d(malloc)->%d(%s) old_r_info=0x%x new_r_info=0x%x\n",
				s.name, j, uint64(recOff), rela.Off, typ, mallocIdx, wrapperIdx, wrapper, oldInfo, rela.Info)
		}
	}

	if patched == 0 {
		fmt.Fprintf(os.Stderr, "no applicable relocations found that reference malloc (dynsym idx %d); nothing patched\n", mallocIdx)
		os.Exit(1)
	}

	if err := os.Chmod(outPath, 0755); err != nil {
		fmt.Fprintf(os.Stderr, "chmod output: %v\n", err)
		os.Exit(1)
	}
	fmt.Fprintf(os.Stderr, "done: patched %d relocation(s) from malloc to %s\n", patched, wrapper)
}
