		if err := readStructAt(inF, off, binary.LittleEndian, &shdrs[i]); err != nil {
			fmt.Fprintf(os.Stderr, "read section header %d: %v\n", i, err)
			os.Exit(1)
		}
	}
	if int(eh.Shstrndx) <= 0 || int(eh.Shstrndx) >= len(shdrs) {
		fmt.Fprintf(os.Stderr, "invalid shstrndx: %d\n", eh.Shstrndx)
		os.Exit(1)
	}
	shstr := shdrs[int(eh.Shstrndx)]

