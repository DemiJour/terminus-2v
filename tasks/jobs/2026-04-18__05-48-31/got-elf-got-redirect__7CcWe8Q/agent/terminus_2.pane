			os.Exit(1)
		}
		if name == "malloc" {
			mallocIdx = uint32(i)
		}
		if name == wrapper {
			wrapperIdx = uint32(i)
		}
	}
	if wrapperIdx == 0 {
		fmt.Fprintf(os.Stderr, "wrapper symbol not found in .dynsym: %s\n", wrapper)
		os.Exit(1)
	}
	if mallocIdx == 0 {
		fmt.Fprintf(os.Stderr, "symbol not found in .dynsym: malloc\n")
		os.Exit(1)
