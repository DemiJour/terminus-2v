		fmt.Fprintf(os.Stderr, "not an ELF file\n")
		os.Exit(1)
	}
	if eh.Ident[EI_CLASS] != ELFCLASS64 {
		fmt.Fprintf(os.Stderr, "unsupported ELF class (need 64-bit)\n")
