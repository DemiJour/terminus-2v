	if dynstrSec.h.Type != SHT_STRTAB {
		fmt.Fprintf(os.Stderr, "warning: dynsym sh_link does not point to STRTAB (type=%d name=%s)\n", dynstrSec.h.Type, dynstrSec.name)
	}

	if dynsymSec.h.Entsize == 0 {
		dynsymSec.h.Entsize = uint64(binary.Size(elf64Sym{}))
	}
