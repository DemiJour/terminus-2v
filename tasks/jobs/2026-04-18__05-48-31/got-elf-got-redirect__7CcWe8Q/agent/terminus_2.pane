	for i := range shdrs {
		name, err := readCStringFrom(inF, int64(shstr.Off), int64(shstr.Size), shdrs[i].Name)
		if err != nil {
			fmt.Fprintf(os.Stderr, "read section name %d: %v\n", i, err)
			os.Exit(1)
		}
		secs[i] = section{h: shdrs[i], name: name, idx: i}
	}

	var dynsymSec *section
	for i := range secs {
		if secs[i].h.Type == SHT_DYNSYM || secs[i].name == ".dynsym" {
			dynsymSec = &secs[i]
			break
		}
	}
	if dynsymSec == nil {
		fmt.Fprintf(os.Stderr, "missing .dynsym; cannot patch\n")
		os.Exit(1)
	}
	if dynsymSec.h.Link >= uint32(len(secs)) {
		fmt.Fprintf(os.Stderr, "dynsym sh_link out of range: %d\n", dynsymSec.h.Link)
		os.Exit(1)
	}
