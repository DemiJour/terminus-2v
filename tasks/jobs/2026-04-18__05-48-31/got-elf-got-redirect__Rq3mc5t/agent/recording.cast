[93.581218, "i", "cat > /app/cmd/got-patch/main.go <<'EOF'\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/binary\"\n\t\"errors\"\n\t\"flag\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n)\n\n// Minimal ELF64 (little-endian) layout parsing using encoding/binary only.\n// We patch relocation records (SHT_RELA) that reference malloc to instead\n// reference wrapperSymbol (default logged_malloc) in .dynsym.\n\nconst (\n\tEI_CLASS      = 4\n\tEI_DATA       = 5\n\tELFCLASS64    = 2\n\tELFDATA2LSB   = 1\n\tET_EXEC       = 2\n\tET_DYN        = 3\n\tSHT_NULL      = 0\n\tSHT_SYMTAB    = 2\n\tSHT_STRTAB    = 3\n\tSHT_RELA      = 4\n\tSHT_DYNSYM    = 11\n)\n\ntype elf64Ehdr struct {\n\tIdent     [16]byte\n\tType      uint16\n\tMachine   uint16\n\tVersion   uint32\n\tEntry     uint64\n\tPhoff     uint64\n\tShoff     uint64\n\tFlags     uint32\n\tEhsize    uint16\n\tPhentsize uint16\n\tPhnum     uint16\n\tShentsize uint16\n\tShnum     uint16\n\tShstrndx  uint16\n}\n\ntype elf64Shdr struct {\n\tName      uint32\n\tType      uint32\n\tFlags     uint64\n\tAddr      uint64\n\tOffset    uint64\n\tSize      uint64\n\tLink      uint32\n\tInfo      uint32\n\tAddral"]
[93.581257, "i", "ign uint64\n\tEntsize   uint64\n}\n\ntype elf64Sym struct {\n\tName  uint32\n\tInfo  uint8\n\tOther uint8\n\tShndx uint16\n\tValue uint64\n\tSize  uint64\n}\n\ntype elf64Rela struct {\n\tOffset uint64\n\tInfo   uint64\n\tAddend int64\n}\n\nfunc rSym(info uint64) uint32  { return uint32(info >> 32) }\nfunc rType(info uint64) uint32 { return uint32(info & 0xffffffff) }\nfunc makeRInfo(sym uint32, typ uint32) uint64 {\n\treturn (uint64(sym) << 32) | uint64(typ)\n}\n\ntype section struct {\n\tidx  int\n\tname string\n\thdr  elf64Shdr\n}\n\nfunc readAtFull(f *os.File, off int64, b []byte) error {\n\tn, err := f.ReadAt(b, off)\n\tif err != nil && !errors.Is(err, io.EOF) {\n\t\treturn err\n\t}\n\tif n != len(b) {\n\t\treturn io.ErrUnexpectedEOF\n\t}\n\treturn nil\n}\n\nfunc cstringFrom(tab []byte, off uint32) string {\n\tif int(off) >= len(tab) {\n\t\treturn \"\"\n\t}\n\tb := tab[off:]\n\ti := bytes.IndexByte(b, 0)\n\tif i < 0 {\n\t\treturn \"\"\n\t}\n\treturn string(b[:i])\n}\n\nfunc main() {\n\tflag.Usage = func() {\n\t\tfmt.Fprintf(os.Stderr, \"usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n\", os.Args[0]"]
[93.581942, "i", ")\n\t}\n\tflag.Parse()\n\targs := flag.Args()\n\tif len(args) != 2 && len(args) != 3 {\n\t\tflag.Usage()\n\t\tos.Exit(2)\n\t}\n\tinPath, outPath := args[0], args[1]\n\twrapperSymbol := \"logged_malloc\"\n\tif len(args) == 3 {\n\t\twrapperSymbol = args[2]\n\t}\n\n\tin, err := os.Open(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: open input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer in.Close()\n\n\tst, err := in.Stat()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: stat input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif st.Size() < 64 {\n\t\tfmt.Fprintf(os.Stderr, \"error: input too small to be ELF64\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t// Read ELF header (64 bytes for ELF64)\n\tvar eh elf64Ehdr\n\tif err := binary.Read(io.NewSectionReader(in, 0, 1<<63-1), binary.LittleEndian, &eh); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: read ELF header: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {\n\t\tfmt.Fprintf(os.Stderr, \"error: not an ELF file\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_CLASS] != ELFCLASS64 {\n\t\tf"]
