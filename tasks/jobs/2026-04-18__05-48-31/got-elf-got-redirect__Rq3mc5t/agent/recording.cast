[93.582329, "i", "8]byte\n\t\t\tbinary.LittleEndian.PutUint64(tmp[:], rela.Info)\n\t\t\tif _, err := out.WriteAt(tmp[:], infoOffInFile); err != nil {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"error: patch write %s[%d]: %v\\n\", s.name, j, err)\n\t\t\t\tos.Exit(1)\n\t\t\t}\n\t\t\tpatched++\n\t\t\tfmt.Fprintf(os.Stderr, \"patched relocation section=%s index=%d r_offset=0x%x r_type=%d r_sym:%d(%s)->%d(%s) old_r_info=0x%x new_r_info=0x%x\\n\",\n\t\t\t\ts.name, j, rela.Offset, typ, sym, \"malloc\", wrapperSym, wrapperSymbol, oldInfo, rela.Info)\n\t\t}\n\t}\n\n\tif patched == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"error: no applicable relocations found targeting symbol malloc\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tif err := out.Close(); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: close output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif err := os.Chmod(outPath, 0755); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: chmod output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Fprintf(os.Stderr, \"done: patched %d relocation(s) from malloc to %s\\n\", patched, wrapperSymbol)\n}\nEOF\n"]
