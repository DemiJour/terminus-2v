[93.582306, "i", ")\n\t\tos.Exit(1)\n\t}\n\n\t// Copy input -> output first, then patch in-place by writing specific bytes.\n\tout, err := os.OpenFile(outPath, os.O_CREATE|os.O_TRUNC|os.O_WRONLY, 0755)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: create output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer out.Close()\n\tif _, err := in.Seek(0, io.SeekStart); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: seek input: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif _, err := io.Copy(out, in); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: copy input to output: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\t// Ensure header prefix (first 64 bytes) identical by design (we copied whole file).\n\t// Now patch relocation sections.\n\tpatched := 0\n\tfor i := range sections {\n\t\ts := &sections[i]\n\t\tif s.hdr.Type != SHT_RELA {\n\t\t\tcontinue\n\t\t}\n\t\t// Only relocation sections whose symbol table is .dynsym (link index)\n\t\tif int(s.hdr.Link) != dynsym.idx {\n\t\t\tcontinue\n\t\t}\n\t\tentsize := s.hdr.Entsize\n\t\tif entsize == 0 {\n\t\t\tentsize = uint64(binary.Size(elf64Rela{}))\n\t\t}\n\t\tif entsize != uint64(binary.Si"]
