[93.582098, "i", "mt.Fprintf(os.Stderr, \"error: expected ELFCLASS64, got %d\\n\", eh.Ident[EI_CLASS])\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\n\t\tfmt.Fprintf(os.Stderr, \"error: expected little-endian ELF, got data=%d\\n\", eh.Ident[EI_DATA])\n\t\tos.Exit(1)\n\t}\n\tif eh.Type != ET_EXEC && eh.Type != ET_DYN {\n\t\tfmt.Fprintf(os.Stderr, \"error: expected ET_EXEC or ET_DYN, got %d\\n\", eh.Type)\n\t\tos.Exit(1)\n\t}\n\tif eh.Shoff == 0 || eh.Shnum == 0 {\n\t\tfmt.Fprintf(os.Stderr, \"error: missing section headers\\n\")\n\t\tos.Exit(1)\n\t}\n\tif eh.Shentsize != uint16(binary.Size(elf64Shdr{})) {\n\t\tfmt.Fprintf(os.Stderr, \"error: unexpected section header entry size %d\\n\", eh.Shentsize)\n\t\tos.Exit(1)\n\t}\n\n\t// Read section headers\n\tshdrs := make([]elf64Shdr, int(eh.Shnum))\n\tshBytes := make([]byte, int(eh.Shentsize)*int(eh.Shnum))\n\tif err := readAtFull(in, int64(eh.Shoff), shBytes); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: read section headers: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfor i := 0; i < int(eh.Shnum); i++ {\n\t\tvar sh elf64Shdr\n\t\toff := i * int(eh.She"]
