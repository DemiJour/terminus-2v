[70.084694, "i", "64Ehdr) ([]section, []byte, error) {\n\tif eh.Shentsize == 0 || eh.Shnum == 0 {\n\t\treturn nil, nil, errors.New(\"no section headers\")\n\t}\n\tif eh.Shentsize != uint16(binary.Size(elf64Shdr{})) {\n\t\treturn nil, nil, fmt.Errorf(\"unexpected section header size: %d\", eh.Shentsize)\n\t}\n\tshdrs := make([]elf64Shdr, int(eh.Shnum))\n\tfor i := 0; i < int(eh.Shnum); i++ {\n\t\tif err := readStructAt(f, int64(eh.Shoff)+int64(i)*int64(eh.Shentsize), &shdrs[i]); err != nil {\n\t\t\treturn nil, nil, fmt.Errorf(\"read shdr[%d]: %w\", i, err)\n\t\t}\n\t}\n\tif int(eh.Shstrndx) >= len(shdrs) {\n\t\treturn nil, nil, fmt.Errorf(\"invalid e_shstrndx %d\", eh.Shstrndx)\n\t}\n\tshstr := shdrs[eh.Shstrndx]\n\tif shstr.Type != SHT_STRTAB {\n\t\treturn nil, nil, fmt.Errorf(\"section header string table is not STRTAB (type=%d)\", shstr.Type)\n\t}\n\tshstrtab, err := readAtFull(f, int64(shstr.Off), int(shstr.Size))\n\tif err != nil {\n\t\treturn nil, nil, fmt.Errorf(\"read .shstrtab: %w\", err)\n\t}\n\tsecs := make([]section, len(shdrs))\n\tfor i := range shdrs {\n\t\tsecs[i] = section{hdr: shdrs["]
[70.084759, "i", "i], name: readCString(shstrtab, shdrs[i].Name), idx: i}\n\t}\n\treturn secs, shstrtab, nil\n}\n\nfunc findSection(secs []section, name string) *section {\n\tfor i := range secs {\n\t\tif secs[i].name == name {\n\t\t\treturn &secs[i]\n\t\t}\n\t}\n\treturn nil\n}\n\nfunc loadDynsym(f *os.File, secs []section) ([]dynsym, []byte, *section, *section, error) {\n\tdyn := findSection(secs, \".dynsym\")\n\tif dyn == nil {\n\t\treturn nil, nil, nil, nil, errors.New(\"missing .dynsym\")\n\t}\n\tif dyn.hdr.Type != SHT_DYNSYM {\n\t\treturn nil, nil, nil, nil, fmt.Errorf(\".dynsym wrong type: %d\", dyn.hdr.Type)\n\t}\n\tif dyn.hdr.Entsize == 0 {\n\t\treturn nil, nil, nil, nil, errors.New(\".dynsym entsize is 0\")\n\t}\n\tif dyn.hdr.Entsize != uint64(binary.Size(elf64Sym{})) {\n\t\treturn nil, nil, nil, nil, fmt.Errorf(\"unexpected .dynsym entsize: %d\", dyn.hdr.Entsize)\n\t}\n\t// Link points to the associated string table (.dynstr)\n\tif int(dyn.hdr.Link) >= len(secs) {\n\t\treturn nil, nil, nil, nil, fmt.Errorf(\".dynsym sh_link out of range: %d\", dyn.hdr.Link)\n\t}\n\tdynstrSec := &secs[dyn.hdr.L"]
[70.084788, "i", "ink]\n\tif dynstrSec.hdr.Type != SHT_STRTAB {\n\t\treturn nil, nil, nil, nil, fmt.Errorf(\".dynsym link section is not STRTAB (type=%d)\", dynstrSec.hdr.Type)\n\t}\n\tdynstr, err := readAtFull(f, int64(dynstrSec.hdr.Off), int(dynstrSec.hdr.Size))\n\tif err != nil {\n\t\treturn nil, nil, nil, nil, fmt.Errorf(\"read .dynstr: %w\", err)\n\t}\n\tcount := int(dyn.hdr.Size / dyn.hdr.Entsize)\n\tsyms := make([]dynsym, 0, count)\n\tfor i := 0; i < count; i++ {\n\t\tvar s elf64Sym\n\t\toff := int64(dyn.hdr.Off) + int64(i)*int64(dyn.hdr.Entsize)\n\t\tif err := readStructAt(f, off, &s); err != nil {\n\t\t\treturn nil, nil, nil, nil, fmt.Errorf(\"read dynsym[%d]: %w\", i, err)\n\t\t}\n\t\tname := readCString(dynstr, s.Name)\n\t\tsyms = append(syms, dynsym{idx: i, sym: s, name: name})\n\t}\n\treturn syms, dynstr, dyn, dynstrSec, nil\n}\n\nfunc patchRelocations(inPath, outPath, wrapper string) error {\n\tinF, err := os.Open(inPath)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer inF.Close()\n\n\tst, err := inF.Stat()\n\tif err != nil {\n\t\treturn err\n\t}\n\tsize := st.Size()\n\tif size < 64 {\n\t\tretur"]
[70.084795, "i", "n fmt.Errorf(\"file too small to be ELF64: %d bytes\", size)\n\t}\n\n\t// Read ELF header but do not modify first 64 bytes.\n\tvar eh elf64Ehdr\n\tif err := readStructAt(inF, 0, &eh); err != nil {\n\t\treturn fmt.Errorf(\"read ELF header: %w\", err)\n\t}\n\tif eh.Ident[0] != 0x7f || eh.Ident[1] != 'E' || eh.Ident[2] != 'L' || eh.Ident[3] != 'F' {\n\t\treturn errors.New(\"not an ELF file\")\n\t}\n\tif eh.Ident[4] != ELFCLASS64 {\n\t\treturn fmt.Errorf(\"unsupported ELF class: %d\", eh.Ident[4])\n\t}\n\tif eh.Ident[5] != ELFDATA2LSB {\n\t\treturn fmt.Errorf(\"unsupported ELF data encoding: %d\", eh.Ident[5])\n\t}\n\tif eh.Shoff == 0 {\n\t\treturn errors.New(\"missing section header table\")\n\t}\n\n\tsecs, _, err := loadSections(inF, eh)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tdynsyms, _, _, _, err := loadDynsym(inF, secs)\n\tif err != nil {\n\t\treturn err\n\t}\n\n\tmallocIdx := -1\n\twrapperIdx := -1\n\tfor _, s := range dynsyms {\n\t\tif s.name == \"malloc\" {\n\t\t\tmallocIdx = s.idx\n\t\t}\n\t\tif s.name == wrapper {\n\t\t\twrapperIdx = s.idx\n\t\t}\n\t}\n\tif wrapperIdx < 0 {\n\t\treturn fmt.Errorf(\"wrapper "]
[70.084831, "i", "symbol not found in .dynsym: %s\", wrapper)\n\t}\n\tif mallocIdx < 0 {\n\t\treturn fmt.Errorf(\"target symbol not found in .dynsym: malloc\")\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"dynsym: malloc idx=%d, %s idx=%d\\n\", mallocIdx, wrapper, wrapperIdx)\n\n\t// Copy input to output first (preserve all bytes), then patch in-place.\n\tif err := os.MkdirAll(filepath.Dir(outPath), 0755); err != nil {\n\t\treturn err\n\t}\n\toutF, err := os.OpenFile(outPath, os.O_CREATE|os.O_TRUNC|os.O_RDWR, 0755)\n\tif err != nil {\n\t\treturn err\n\t}\n\tdefer outF.Close()\n\tif _, err := inF.Seek(0, io.SeekStart); err != nil {\n\t\treturn err\n\t}\n\tif _, err := io.Copy(outF, inF); err != nil {\n\t\treturn err\n\t}\n\tif err := outF.Chmod(0755); err != nil {\n\t\treturn err\n\t}\n\n\tpatched := 0\n\tfor _, sec := range secs {\n\t\tif sec.hdr.Type != SHT_RELA {\n\t\t\tcontinue\n\t\t}\n\t\tif sec.hdr.Entsize == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tif sec.hdr.Entsize != uint64(binary.Size(elf64Rela{})) {\n\t\t\tcontinue\n\t\t}\n\t\tcount := int(sec.hdr.Size / sec.hdr.Entsize)\n\t\tif count == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Many relocation secti"]
[70.084849, "i", "ons that refer to dynsym will have sh_link == dynsym index.\n\t\tif int(sec.hdr.Link) >= len(secs) {\n\t\t\tcontinue\n\t\t}\n\t\tif secs[sec.hdr.Link].name != \".dynsym\" {\n\t\t\tcontinue\n\t\t}\n\n\t\tfor i := 0; i < count; i++ {\n\t\t\tvar r elf64Rela\n\t\t\toff := int64(sec.hdr.Off) + int64(i)*int64(sec.hdr.Entsize)\n\t\t\tif err := readStructAt(outF, off, &r); err != nil {\n\t\t\t\treturn fmt.Errorf(\"read rela %s[%d]: %w\", sec.name, i, err)\n\t\t\t}\n\t\t\tsym := relaSym(r.Info)\n\t\t\ttyp := relaType(r.Info)\n\t\t\tif int(sym) == mallocIdx {\n\t\t\t\tnewInfo := makeRelaInfo(uint32(wrapperIdx), typ)\n\t\t\t\tfmt.Fprintf(os.Stderr, \"patch relocation: section=%s index=%d r_offset=0x%x type=%d sym=%d(malloc)->%d(%s)\\n\",\n\t\t\t\t\tsec.name, i, r.Off, typ, mallocIdx, wrapperIdx, wrapper)\n\t\t\t\tr.Info = newInfo\n\t\t\t\tvar buf bytes.Buffer\n\t\t\t\tif err := binary.Write(&buf, binary.LittleEndian, &r); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t\tif _, err := outF.WriteAt(buf.Bytes(), off); err != nil {\n\t\t\t\t\treturn fmt.Errorf(\"write rela %s[%d]: %w\", sec.name, i, err)\n\t\t\t\t}\n\t\t\t\tpatched++\n\t\t\t}\n\t\t}\n\t"]
[70.085059, "i", "}\n\n\tif patched == 0 {\n\t\treturn fmt.Errorf(\"no applicable RELA relocations referenced symbol malloc (idx=%d); nothing patched\", mallocIdx)\n\t}\n\tfmt.Fprintf(os.Stderr, \"patched %d relocation(s) targeting malloc -> %s\\n\", patched, wrapper)\n\treturn nil\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, \"usage: got-patch <input_elf> <output_elf> [wrapper_symbol]\\n\")\n}\n\nfunc main() {\n\tif len(os.Args) != 3 && len(os.Args) != 4 {\n\t\tusage()\n\t\tos.Exit(2)\n\t}\n\tinPath := os.Args[1]\n\toutPath := os.Args[2]\n\twrapper := \"logged_malloc\"\n\tif len(os.Args) == 4 {\n\t\twrapper = os.Args[3]\n\t}\n\tif err := patchRelocations(inPath, outPath, wrapper); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\nEOF\n"]
