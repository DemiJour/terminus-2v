urn ""\n\t}\n\tb := tab[off:]\n\ti := bytes.IndexByte(b, 0)\n\tif i < 0 {\n\t\treturn ""\n\t}\n\treturn string(b[:i])\n}\n\nfunc main() {\n\tflag.Usage = func() {\n\t\tfmt.Fprintf(os.Stderr, "usage: %s <input_elf> <output_elf> [wrapper_symbol]\\n", os.Args[0])\n\t}\n\tflag.Parse()\n\targs := flag.Args()\n\tif len(args) != 2 && len(args) != 3 {\n\t\tflag.Usage()\n\t\tos.Exit(2)\n\t}\n\tinPath, outPath := args[0], args[1]\n\twrapperSymbol := "logged_malloc"\n\tif len(args) == 3 {\n\t\twrapperSymbol = args[2]\n\t}\n\n\tin, err := os.Open(inPath)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, "error: open input: %v\\n", err)\n\t\tos.Exit(1)\n\t}\n\tdefer in.Close()\n\n\tst, err := in.Stat()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, "error: stat input: %v\\n", err)\n\t\tos.Exit(1)\n\t}\n\tif st.Size() < 64 {\n\t\tfmt.Fprintf(os.Stderr, "error: input too small to be ELF64\\n")\n\t\tos.Exit(1)\n\t}\n\n\t// Read ELF header (64 bytes for ELF64)\n\tvar eh elf64Ehdr\n\tif err := binary.Read(io.NewSectionReader(in, 0, 1<<63-1), binary.LittleEndian, &eh); err != nil {\n\t\tfmt.Fprintf(os.Stderr, "error: read ELF header: %v\\n", err)\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[0] != 0x7f || eh.Ident[1] != \'E\' || eh.Ident[2] != \'L\' || eh.Ident[3] != \'F\' {\n\t\tfmt.Fprintf(os.Stderr, "error: not an ELF file\\n")\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_CLASS] != ELFCLASS64 {\n\t\tfmt.Fprintf(os.Stderr, "error: expected ELFCLASS64, got %d\\n", eh.Ident[EI_CLASS])\n\t\tos.Exit(1)\n\t}\n\tif eh.Ident[EI_DATA] != ELFDATA2LSB {\n\t\tfmt.Fprintf(os.Stderr, "error: expected little-endian ELF, got data=%d\\n", eh.Ident[EI_DATA])\n\t\tos.Exit(1)\n\t}\n\tif eh.Type != ET_EXEC && eh.Type != ET_DYN {\n\t\tfmt.Fprintf(os.Stderr, "error: expected ET_EXEC or ET_DYN, got %d\\n", eh.Type)\n\t\tos.Exit(1)\n\t}\n\tif eh.Shoff == 0 || eh.Shnum == 0 {\n\t\tfmt.Fprintf(os.Stderr, "error: missing section headers\\n")\n\t\tos.Exit(1)\n\t}\n\tif eh.Shentsize != uint16(binary.Size(elf64Shdr{})) {\n\t\tfmt.