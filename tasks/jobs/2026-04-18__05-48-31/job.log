err := readAtFull(in, int64(dynstr.hdr.Offset), dynStrTab); err != nil {\n\t\tfmt.Fprintf(os.Stderr, "error: read .dynstr: %v\\n", err)\n\t\tos.Exit(1)\n\t}\n\t// Load dynsym\n\tif dynsym.hdr.Entsize == 0 {\n\t\tdynsym.hdr.Entsize = uint64(binary.Size(elf64Sym{}))\n\t}\n\tif dynsym.hdr.Entsize != uint64(binary.Size(elf64Sym{})) {\n\t\tfmt.Fprintf(os.Stderr, "error: unexpected .dynsym entsize=%d\\n", dynsym.hdr.Entsize)\n\t\tos.Exit(1)\n\t}\n\tif dynsym.hdr.Size%dynsym.hdr.Entsize != 0 {\n\t\tfmt.Fprintf(os.Stderr, "error: .dynsym size not multiple of entsize\\n")\n\t\tos.Exit(1)\n\t}\n\tsymCount := int(dynsym.hdr.Size / dynsym.hdr.Entsize)\n\tdynSymBytes := make([]byte, int(dynsym.hdr.Size))\n\tif err := readAtFull(in, int64(dynsym.hdr.Offset), dynSymBytes); err != nil {\n\t\tfmt.Fprintf(os.Stderr, "error: read .dynsym: %v\\n", err)\n\t\tos.Exit(1)\n\t}\n\tnameBySym := make([]string, symCount)\n\tfor i := 0; i < symCount; i++ {\n\t\tvar sym elf64Sym\n\t\toff := i * int(dynsym.hdr.Entsize)\n\t\tif err := binary.Read(bytes.NewReader(dynSymBytes[off:off+int(dynsym.hdr.Entsize)]), binary.LittleEndian, &sym); err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, "error: parse dynsym %d: %v\\n", i, err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tnameBySym[i] = cstringFrom(dynStrTab, sym.Name)\n\t}\n\n\tmallocSym := -1\n\twrapperSym := -1\n\tfor i, n := range nameBySym {\n\t\tif n == "malloc" {\n\t\t\tmallocSym = i\n\t\t}\n\t\tif n == wrapperSymbol {\n\t\t\twrapperSym = i\n\t\t}\n\t}\n\tif wrapperSym < 0 {\n\t\tfmt.Fprintf(os.Stderr, "error: wrapper symbol not found in .dynsym: %s\\n", wrapperSymbol)\n\t\tos.Exit(1)\n\t}\n\tif mallocSym < 0 {\n\t\t// still possible relocations reference malloc via versioned name, but readelf output suggests plain malloc.\n\t\tfmt.Fprintf(os.Stderr, "error: symbol not found in .dynsym: malloc\\n")\n\t\tos.Exit(1)\n\t}\n\n\t// Copy input -> output first, then patch in-place by writing specific bytes.\n\tout, err := os.OpenFile(outPath, os.O_CREATE|os.O_TRUNC|os.O_W