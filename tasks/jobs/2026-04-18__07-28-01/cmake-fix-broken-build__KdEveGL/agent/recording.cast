[33.883583, "o", "#include <iostream>\r\n#include \"engine.h\"\r\n#include \"plugin.h\"\r\n#include \"build_profile.h\"\r\n\r\nint main() {\r\n    auto result = engine::validate(\"hello\");\r\n"]
[33.883632, "o", "    if (result.has_value()) {\r\n        auto [text, h] = engine::process(\"hello\");\r\n        std::cout << \"text: \" << text << \"\\n\";\r\n        std::cout << \"hash: \" << to_hex(h) << \"\\n\";\r\n        if constexpr (sizeof(int) >= 4) {\r\n            std::cout << \"valid: yes\\n\";\r\n        }\r\n        std::cout << banner(std::string(build_profile())) << \"\\n\";\r\n    }\r\n    return 0;\r\n}\r\n"]
[33.884182, "o", "\u001b[?2004hroot@jour-VMware-Virtual-Platform:/app# "]
[33.989605, "i", "sed -n '1,220p' app/selfcheck.cpp\n"]
