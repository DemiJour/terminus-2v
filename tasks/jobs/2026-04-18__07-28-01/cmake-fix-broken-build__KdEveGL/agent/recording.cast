[33.993788, "o", "#include <iostream>\r\n#include \"engine.h\"\r\n#include \"plugin.h\"\r\n#include \"build_profile.h\"\r\n\r\nint main() {\r\n    auto check = engine::validate(\"harbor\");\r\n    if (!check.has_value()) {\r\n        return 2;\r\n    }\r\n\r\n    auto [text, hash] = engine::process(\"harbor\");\r\n    if (text != \"HARBOR\") {\r\n        return 3;\r\n    }\r\n\r\n    if (to_hex(hash).empty()) {\r\n        return 4;\r\n    }\r\n\r\n    std::cout << \"selfcheck: ok (\" << build_profile() << \")\\n\";\r\n    return 0;\r\n}\r\n\u001b[?2004hroot@jour-VMware-Virtual-Platform:/app# "]
