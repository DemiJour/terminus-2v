[155.019531, "i", "python3 - <<'PY'\nimport json\np='/tmp/build-ninja-debug/compile_commands.json'\nwith open(p) as f:\n    cc=json.load(f)\nfor want in ('/app/engine/engine.cpp','/app/app/main.cpp'):\n    for e in cc:\n        if e.get('file')==want:\n            cmd=e.get('command','')\n            print(want, '=>', ('-std=gnu++20' in cmd) or ('-std=c++20' in cmd), '\\n  ', cmd)\n            break\nPY\n"]
[155.02962, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> p='/tmp/build-ninja-debug/compile_commands.json'\r\n\u001b[?2004l\r\u001b[?2004h> with open(p) as f:\r\n\u001b[?2004l\r\u001b[?2004h>     cc=json.load(f)\r\n\u001b[?2004l\r\u001b[?2004h> for want in ('/app/engine/engine.cpp','/app/app/main.cpp'):\r\n\u001b[?2004l\r\u001b[?2004h>     for e in cc:\r\n\u001b[?2004l\r\u001b[?2004h>         if e.get('file')==want:\r\n\u001b[?2004l\r\u001b[?2004h>             cmd=e.get('command','')\r\n\u001b[?2004l\r\u001b[?2004h>             print(want, '=>', ('-std=gnu++20' in cmd) or ('-std=c++20' in cmd), '\\n  ', cmd)\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
