[32.785244, "o", "sed -n '1,200p' engine/engine.cpp"]
[32.785285, "o", "\r\n\u001b[?2004l\r"]
[32.788204, "o", "#include \"engine.h\"\r\n#include \"core.h\"\r\n#include <algorithm>\r\n#include <cctype>\r\n#include <span>\r\n#include <thread>\r\n\r\nnamespace {\r\n"]
[32.788307, "o", "bool has_nonzero(std::span<const int> values) {\r\n    for (int value : values) {\r\n        if (value != 0) {\r\n            return true;\r\n        }\r\n    }\r\n    return false;\r\n}\r\n}\r\n\r\nnamespace engine {\r\nstd::tuple<std::string, int> process(const std::string& input) {\r\n    auto encoded = core::encode(input);\r\n    auto decoded = core::decode(encoded);\r\n    int h = static_cast<int>(core::hash(decoded));\r\n\r\n    std::string upper(decoded.size(), '\\0');\r\n    std::thread worker([&]() {\r\n        std::transform(decoded.begin(), decoded.end(), upper.begin(), [](unsigned char c) {\r\n            return static_cast<char>(std::toupper(c));\r\n        });\r\n    });\r\n    worker.join();\r\n\r\n    if (!has_nonzero(std::span<const int>(encoded.data(), encoded.size()))) {\r\n        return {upper, h};\r\n    }\r\n    return {upper, h};\r\n}\r\n\r\nstd::optional<std::string> validate(const std::string& input) {\r\n    if (input.empty()) {\r\n        return std::nullopt;\r\n    }\r\n    auto [text, h] = process(input);\r\n"]
[32.78839, "o", "    if (h == 0) {\r\n        return std::nullopt;\r\n    }\r\n    return text;\r\n}\r\n}\r\n"]
[32.788907, "o", "\u001b[?2004hroot@jour-VMware-Virtual-Platform:/app# "]
