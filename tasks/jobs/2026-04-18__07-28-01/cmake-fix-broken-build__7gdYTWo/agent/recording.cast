[65.473026, "i", "cat > /app/app/CMakeLists.txt <<'EOF'\nset(_generated_dir \"${CMAKE_CURRENT_BINARY_DIR}/generated\")\nfile(MAKE_DIRECTORY \"${_generated_dir}\")\n\n# Single-config generators (Ninja/Makefiles): CMAKE_BUILD_TYPE is known at configure time.\nset(BUILD_PROFILE \"${CMAKE_BUILD_TYPE}\")\nif(BUILD_PROFILE STREQUAL \"\")\n  set(BUILD_PROFILE \"Unknown\")\nendif()\n\nconfigure_file(\n  \"${CMAKE_CURRENT_SOURCE_DIR}/build_profile.h.in\"\n  \"${_generated_dir}/build_profile.h\"\n  @ONLY\n)\n\nadd_executable(myapp main.cpp)\ntarget_link_libraries(myapp PRIVATE engine)\ntarget_include_directories(myapp PRIVATE \"${_generated_dir}\")\ntarget_compile_features(myapp PRIVATE cxx_std_20)\n\nadd_executable(selfcheck selfcheck.cpp)\ntarget_link_libraries(selfcheck PRIVATE engine)\ntarget_include_directories(selfcheck PRIVATE \"${_generated_dir}\")\ntarget_compile_features(selfcheck PRIVATE cxx_std_20)\nEOF\n"]
