[107.949547, "i", "cat > /app/app/CMakeLists.txt <<'EOF'\nset(_generated_inc_dir \"${CMAKE_CURRENT_BINARY_DIR}/generated\")\nfile(MAKE_DIRECTORY \"${_generated_inc_dir}\")\n\nconfigure_file(\n  \"${CMAKE_CURRENT_SOURCE_DIR}/build_profile.h.in\"\n  \"${_generated_inc_dir}/build_profile.h\"\n  @ONLY\n)\n\nadd_executable(myapp main.cpp)\ntarget_include_directories(myapp PRIVATE \"${_generated_inc_dir}\")\n# Link to plugin target for usage requirements (include dirs), but consume it as objects.\ntarget_link_libraries(myapp PRIVATE engine plugin)\ntarget_sources(myapp PRIVATE $<TARGET_OBJECTS:plugin>)\ntarget_compile_features(myapp PRIVATE cxx_std_20)\n\nadd_executable(selfcheck selfcheck.cpp)\ntarget_include_directories(selfcheck PRIVATE \"${_generated_inc_dir}\")\ntarget_link_libraries(selfcheck PRIVATE engine plugin)\ntarget_sources(selfcheck PRIVATE $<TARGET_OBJECTS:plugin>)\ntarget_compile_features(selfcheck PRIVATE cxx_std_20)\nEOF\n"]
